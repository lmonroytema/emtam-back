          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/tables",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "tables"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json && Array.isArray(json.tables) && json.tables.length > 0) {",
              "  pm.collectionVariables.set(\"crudTable\", json.tables[0]);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
